[project]
name = "automaton-auditor-swarm"
version = "0.1.0"
description = "Deep LangGraph Multi-Agent System for Forensic Code Auditing"
readme = "README.md"
requires-python = ">=3.11"
license = { text = "MIT" }
authors = [
    { name = "Addisu Taye", email = "addisu.taye@example.com" }
]
keywords = ["langgraph", "multi-agent", "forensic-audit", "code-governance"]
classifiers = [
    "Development Status :: 3 - Alpha",
    "Intended Audience :: Developers",
    "License :: OSI Approved :: MIT License",
    "Programming Language :: Python :: 3.11",
    "Programming Language :: Python :: 3.12",
    "Topic :: Software Development :: Quality Assurance",
]

# =============================================================================
# CORE DEPENDENCIES
# =============================================================================

dependencies = [
    # LangGraph & LangChain Core
    "langgraph>=0.2.0",
    "langchain>=0.3.0",
    "langchain-core>=0.3.0",
    
    # LLM Providers
    "langchain-openai>=0.2.0",
    "langchain-anthropic>=0.2.0",
    
    # State Management & Validation
    "pydantic>=2.0.0",
    "python-dotenv>=1.0.0",
    "typing-extensions>=4.0.0",
    
    # Forensic Tools
    "gitpython>=3.1.0",
    "tree-sitter>=0.21.0",
    "tree-sitter-python>=0.21.0",
    
    # Document Processing
    "pypdf>=4.0.0",
    "pdfplumber>=0.11.0",
    
    # Observability
    "langsmith>=0.1.0",
    
    # HTTP & Async
    "httpx>=0.27.0",
    "aiohttp>=3.9.0",
]

# =============================================================================
# DEVELOPMENT DEPENDENCIES (uv 0.5+ format)
# =============================================================================

[dependency-groups]
dev = [
    "pytest>=8.0.0",
    "pytest-asyncio>=0.23.0",
    "pytest-cov>=4.1.0",
    "black>=24.0.0",
    "ruff>=0.4.0",
    "mypy>=1.0.0",
    "pre-commit>=3.0.0",
]

docs = [
    "mkdocs>=1.5.0",
    "mkdocs-material>=9.0.0",
    "mkdocstrings[python]>=0.24.0",
]

# =============================================================================
# UV CONFIGURATION
# =============================================================================

[tool.uv]
# Use latest compatible versions within specified ranges
# Note: upgrade is a boolean, not a string
upgrade-package = []

# =============================================================================
# BUILD SYSTEM
# =============================================================================

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src"]

# =============================================================================
# LINTING & FORMATTING
# =============================================================================

[tool.ruff]
line-length = 100
target-version = "py311"

[tool.ruff.lint]
select = [
    "E",   # pycodestyle errors
    "F",   # pyflakes
    "I",   # isort
    "N",   # pep8-naming
    "UP",  # pyupgrade
    "B",   # flake8-bugbear
]
ignore = [
    "E501",  # Line length handled by formatter
]

[tool.ruff.lint.isort]
known-first-party = ["src"]

[tool.black]
line-length = 100
target-version = ["py311", "py312"]

# =============================================================================
# TYPE CHECKING
# =============================================================================

[tool.mypy]
python_version = "3.11"
strict = true
warn_return_any = true
warn_unused_configs = true
disallow_untyped_defs = true
disallow_incomplete_defs = true

[[tool.mypy.overrides]]
module = [
    "git.*",
    "tree_sitter.*",
    "pypdf.*",
    "pdfplumber.*",
]
ignore_missing_imports = true

# =============================================================================
# PYTEST CONFIGURATION
# =============================================================================

[tool.pytest.ini_options]
minversion = "8.0"
addopts = [
    "-ra",
    "--strict-markers",
    "--strict-config",
    "--cov=src",
    "--cov-report=term-missing",
]
testpaths = ["tests"]
python_files = ["test_*.py", "*_test.py"]
python_classes = ["Test*"]
python_functions = ["test_*"]
markers = [
    "unit: Unit tests",
    "integration: Integration tests",
    "slow: Tests that take longer than 5 seconds",
]
asyncio_mode = "auto"