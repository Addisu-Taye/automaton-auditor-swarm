# =============================================================================
# Automaton Auditor Swarm - Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider (Required)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o
# Optional fallback
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# -----------------------------------------------------------------------------
# LangSmith Observability (Optional but Recommended)
# -----------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__your-langsmith-key-here
LANGCHAIN_PROJECT=automaton-auditor-swarm
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# -----------------------------------------------------------------------------
# API Server Configuration
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
ENV=production  # or 'development' for hot reload

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Docker Configuration
# -----------------------------------------------------------------------------
# Copy this file to .env before running docker compose
# docker compose --env-file .env up -d